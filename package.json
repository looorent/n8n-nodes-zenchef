{
  "name": "n8n-nodes-zenchef",
  "version": "0.2.1",
  "description": "Custom N8N Node to contact Zenchef's API",
  "license": "MIT",
  "homepage": "https://github.com/looorent/n8n-nodes-zenchef",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Lorent Lempereur",
    "email": "lorent.lempereur@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/looorent/n8n-nodes-zenchef.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [],
    "nodes": [
      "dist/nodes/Zenchef/Zenchef.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.3",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "release-it": {
    "hooks": {
      "before:init": [
        "npm run lint",
        "npm run build"
      ]
    },
    "git": {
      "commit": true,
      "tag": true,
      "tagName": "v${version}"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true
    }
  }
}
